      <div class="editor flex lazy-editor" style=""><pre class="lazy-virtualized" style="font-size: 14px; line-height: 19px;" tabindex="0"><pre class="lazy-gutter"></pre><pre class="monaco-colorized colab-dark colab-dark" data-lang="notebook-python"><span><span class="mtk10">def</span><span class="mtk1">&nbsp;</span><span class="mtk17">check_multiply_compatible</span><span class="mtk1">(</span><span class="mtk4">A</span><span class="mtk1">,&nbsp;</span><span class="mtk4">B</span><span class="mtk1">)</span><span class="mtk14">:</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk5">"""</span></span><br><span><span class="mtk5">&nbsp;&nbsp;&nbsp;&nbsp;Check&nbsp;if&nbsp;two&nbsp;matrices&nbsp;can&nbsp;be&nbsp;multiplied.</span></span><br><span><span class="mtk5">&nbsp;&nbsp;&nbsp;&nbsp;This&nbsp;helps&nbsp;avoid&nbsp;shape&nbsp;errors!</span></span><br><span><span class="mtk5">&nbsp;&nbsp;&nbsp;&nbsp;"""</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;A_shape&nbsp;=&nbsp;np.array</span><span class="mtk14">(</span><span class="mtk1">A</span><span class="mtk14">)</span><span class="mtk1">.shape</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;B_shape&nbsp;=&nbsp;np.array</span><span class="mtk14">(</span><span class="mtk1">B</span><span class="mtk14">)</span><span class="mtk1">.shape</span></span><br><span><span></span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk17">print</span><span class="mtk14">(</span><span class="mtk10">f</span><span class="mtk5">"Matrix&nbsp;A&nbsp;shape:&nbsp;</span><span class="mtk14">{</span><span class="mtk1">A_shape</span><span class="mtk14">}</span><span class="mtk5">"</span><span class="mtk14">)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk17">print</span><span class="mtk14">(</span><span class="mtk10">f</span><span class="mtk5">"Matrix&nbsp;B&nbsp;shape:&nbsp;</span><span class="mtk14">{</span><span class="mtk1">B_shape</span><span class="mtk14">}</span><span class="mtk5">"</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk20">if</span><span class="mtk1">&nbsp;</span><span class="mtk17">len</span><span class="mtk14">(</span><span class="mtk1">A_shape</span><span class="mtk14">)</span><span class="mtk1">&nbsp;==&nbsp;</span><span class="mtk6">2</span><span class="mtk1">&nbsp;</span><span class="mtk19">and</span><span class="mtk1">&nbsp;</span><span class="mtk17">len</span><span class="mtk14">(</span><span class="mtk1">B_shape</span><span class="mtk14">)</span><span class="mtk1">&nbsp;==&nbsp;</span><span class="mtk6">2</span><span class="mtk14">:</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk20">if</span><span class="mtk1">&nbsp;A_shape</span><span class="mtk14">[</span><span class="mtk6">1</span><span class="mtk14">]</span><span class="mtk1">&nbsp;==&nbsp;B_shape</span><span class="mtk14">[</span><span class="mtk6">0</span><span class="mtk14">]:</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk17">print</span><span class="mtk14">(</span><span class="mtk10">f</span><span class="mtk5">"✓&nbsp;Can&nbsp;multiply!&nbsp;Result&nbsp;shape&nbsp;will&nbsp;be:&nbsp;(</span><span class="mtk14">{</span><span class="mtk1">A_shape</span><span class="mtk14">[</span><span class="mtk6">0</span><span class="mtk14">]}</span><span class="mtk5">,&nbsp;</span><span class="mtk14">{</span><span class="mtk1">B_shape</span><span class="mtk14">[</span><span class="mtk6">1</span><span class="mtk14">]}</span><span class="mtk5">)"</span><span class="mtk14">)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk20">return</span><span class="mtk1">&nbsp;</span><span class="mtk9">True</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk20">else</span><span class="mtk14">:</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk17">print</span><span class="mtk14">(</span><span class="mtk10">f</span><span class="mtk5">"✗&nbsp;Cannot&nbsp;multiply!&nbsp;A&nbsp;has&nbsp;</span><span class="mtk14">{</span><span class="mtk1">A_shape</span><span class="mtk14">[</span><span class="mtk6">1</span><span class="mtk14">]}</span><span class="mtk5">&nbsp;columns&nbsp;but&nbsp;B&nbsp;has&nbsp;</span><span class="mtk14">{</span><span class="mtk1">B_shape</span><span class="mtk14">[</span><span class="mtk6">0</span><span class="mtk14">]}</span><span class="mtk5">&nbsp;rows"</span><span class="mtk14">)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk17">print</span><span class="mtk14">(</span><span class="mtk10">f</span><span class="mtk5">"&nbsp;&nbsp;&nbsp;These&nbsp;must&nbsp;be&nbsp;equal!"</span><span class="mtk14">)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk20">return</span><span class="mtk1">&nbsp;</span><span class="mtk9">False</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk20">return</span><span class="mtk1">&nbsp;</span><span class="mtk9">None</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Test&nbsp;it</span></span><br><span><span class="mtk1">a&nbsp;=&nbsp;</span><span class="mtk14">[[</span><span class="mtk6">1</span><span class="mtk14">,</span><span class="mtk6">2</span><span class="mtk14">,</span><span class="mtk6">3</span><span class="mtk14">],[</span><span class="mtk6">2</span><span class="mtk14">,</span><span class="mtk6">