      <div class="editor flex lazy-editor" style=""><pre class="lazy-virtualized" style="font-size: 14px; line-height: 19px;" tabindex="0"><pre class="lazy-gutter"></pre><pre class="monaco-colorized colab-dark colab-dark colab-dark colab-dark" data-lang="notebook-python"><span><span class="mtk20">import</span><span class="mtk1">&nbsp;numpy&nbsp;</span><span class="mtk20">as</span><span class="mtk1">&nbsp;np</span></span><br><span><span class="mtk20">import</span><span class="mtk1">&nbsp;matplotlib.pyplot&nbsp;</span><span class="mtk20">as</span><span class="mtk1">&nbsp;plt</span></span><br><span><span class="mtk8">#&nbsp;Let's&nbsp;see&nbsp;what&nbsp;transpose&nbsp;looks&nbsp;like&nbsp;visually</span></span><br><span><span class="mtk1">fig</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk14">(</span><span class="mtk1">ax1</span><span class="mtk14">,</span><span class="mtk1">&nbsp;ax2</span><span class="mtk14">)</span><span class="mtk1">&nbsp;=&nbsp;plt.subplots</span><span class="mtk14">(</span><span class="mtk6">1</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk6">2</span><span class="mtk14">,</span><span class="mtk1">&nbsp;figsize=</span><span class="mtk14">(</span><span class="mtk6">10</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk6">4</span><span class="mtk14">))</span></span><br><span><span class="mtk1">a&nbsp;=&nbsp;np.array</span><span class="mtk14">([[</span><span class="mtk6">1</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk6">8</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk6">3</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk6">12</span><span class="mtk14">],</span><span class="mtk1">&nbsp;</span><span class="mtk14">[</span><span class="mtk6">2</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk6">6</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk6">4</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk6">7</span><span class="mtk14">]])</span></span><br><span><span class="mtk1">b&nbsp;=&nbsp;a.T</span></span><br><span><span class="mtk8">#&nbsp;Original&nbsp;matrix</span></span><br><span><span class="mtk1">ax1.imshow</span><span class="mtk14">(</span><span class="mtk1">a</span><span class="mtk14">,</span><span class="mtk1">&nbsp;cmap=</span><span class="mtk5">'gray'</span><span class="mtk14">,</span><span class="mtk1">&nbsp;aspect=</span><span class="mtk5">'auto'</span><span class="mtk14">)</span></span><br><span><span class="mtk1">ax1.set_title</span><span class="mtk14">(</span><span class="mtk5">'Original&nbsp;Matrix&nbsp;(2&nbsp;rows&nbsp;×&nbsp;4&nbsp;columns)'</span><span class="mtk14">)</span></span><br><span><span class="mtk1">ax1.set_xlabel</span><span class="mtk14">(</span><span class="mtk5">'Columns'</span><span class="mtk14">)</span></span><br><span><span class="mtk1">ax1.set_ylabel</span><span class="mtk14">(</span><span class="mtk5">'Rows'</span><span class="mtk14">)</span></span><br><span><span class="mtk20">for</span><span class="mtk1">&nbsp;i&nbsp;</span><span class="mtk19">in</span><span class="mtk1">&nbsp;</span><span class="mtk17">range</span><span class="mtk14">(</span><span class="mtk1">a.shape</span><span class="mtk14">[</span><span class="mtk6">0</span><span class="mtk14">]):</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk20">for</span><span class="mtk1">&nbsp;j&nbsp;</span><span class="mtk19">in</span><span class="mtk1">&nbsp;</span><span class="mtk17">range</span><span class="mtk14">(</span><span class="mtk1">a.shape</span><span class="mtk14">[</span><span class="mtk6">1</span><span class="mtk14">]):</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;ax1.text</span><span class="mtk14">(</span><span class="mtk1">j</span><span class="mtk14">,</span><span class="mtk1">&nbsp;i</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk16">str</span><span class="mtk14">(</span><span class="mtk1">a</span><span class="mtk14">[</span><span class="mtk1">i</span><span class="mtk14">,</span><span class="mtk1">&nbsp;j</span><span class="mtk14">]),</span><span class="mtk1">&nbsp;ha=</span><span class="mtk5">'center'</span><span class="mtk14">,</span><span class="mtk1">&nbsp;va=</span><span class="mtk5">'center'</span><span class="mtk14">,</span><span class="mtk1">&nbsp;fontweight=</span><span class="mtk5">'bold'</span><span class="mtk14">)</span></span><br><span><span class="mtk8">#&nbsp;Transposed&nbsp;matrix</span></span><br><span><span class="mtk1">ax2.imshow</span><span class="mtk14">(</span><span class="mtk1">b</span><span class="mtk14">,</span><span class="mtk1">&nbsp;cmap=</span><span class="mtk5">'Blues'</span><span class="mtk14">,</span><span class="mtk1">&nbsp;aspect=</span><span class="mtk5">'auto'</span><span class="mtk14">)</span></span><br><span><span class="mtk1">ax2.set_title</span><span class="mtk14">(</span><span class="mtk5">'Transposed&nbsp;Matrix&nbsp;(4&nbsp;rows&nbsp;×&nbsp;2&nbsp;columns)'</span><span class="mtk14">)</span></span><br><span><span class="mtk1">ax2.set_xlabel</span><span class="mtk14">(</span><span class="mtk5">'Columns'</span><span class="mtk14">)</span></span><br><span><span class="mtk1">ax2.set_ylabel</span><span class="mtk14">(</span><span class="mtk5">'Rows'</span><span class="mtk14">)</span></span><br><span><span class="mtk20">for</span><span class="mtk1">&nbsp;i&nbsp;</span><span class="mtk19">in</span><span class="mtk1">&nbsp;</span><span class="mtk17">range</span><span class="mtk14">(</span><span class="mtk1">b.shape</span><span class="mtk14">[</span><span class="mtk6">0</span><span class="mtk14">]):</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk20">for</span><span class="mtk1">&nbsp;j&nbsp;</span><span class="mtk19">in</span><span class="mtk1">&nbsp;</span><span class="mtk17">range</span><span class="mtk14">(</span><span class="mtk1">b.shape</span><span class="mtk14">[</span><span class="mtk6">1</span><span class="mtk14">]):</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;ax2.text</span><span class="mtk14">(</span><span class="mtk1">j</span><span class="mtk14">,</span><span class="mtk1">&nbsp;i</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk16">str</span><span class="mtk14">(</span><span class="mtk1">b</span><span class="mtk14">[</span><span class="mtk1">i</span><span class="mtk14">,</span><span class="mtk1">&nbsp;j</span><span class="mtk14">]),</span><span class="mtk1">&nbsp;ha=</span><span class="mtk5">'center'</span><span class="mtk14">,</span><span class="mtk1">&nbsp;va=</span><span class="mtk5">'center'</span><span class="mtk14">,</span><span class="mtk1">&nbsp;fontweight=</span><span class="mtk5">'bold'</span><span class="mtk14">)</span></span><br><span><span class="mtk1">plt.tight_layout</span><span class="mtk14">()</span></span><br><span><span class="mtk1">plt.show</span><span class="mtk14">()</span></span><br></pre><colab-read-only-cell-placeholder style="display: none;"><template shadowrootmode="open"><!----><div><!--?lit$286665583$-->Start coding or <span role="button" class="link" tabindex="0">generate</span> with AI.</div></template></colab-read-only-cell-placeholder></pre></div><colab-form class="formview vertical layout flex"><div class="widget-area"></div></colab-form></div>
